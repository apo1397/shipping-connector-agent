# LLM Configuration
LLM_PROVIDER=nvidia  # Options: nvidia, openai, or any OpenAI-compatible provider
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-ai/deepseek-v3.2
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Fetcher Configuration (timeouts in seconds)
FETCHER_TIMEOUT=30
FETCHER_MAX_PAGES=10

# LLM Retry Configuration
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1
