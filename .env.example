# LLM Configuration
LLM_PROVIDER=anthropic  # Options: anthropic, openai, deepseek, nvidia
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-3-5-sonnet-20241022

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Fetcher Configuration (timeouts in seconds)
FETCHER_TIMEOUT=30
FETCHER_MAX_PAGES=10

# LLM Retry Configuration
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1
